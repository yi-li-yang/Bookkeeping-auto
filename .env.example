# Copy this file to .env and fill in your values

# Anthropic — required for LLM categorisation and PDF parsing
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Monzo personal access token — from https://developers.monzo.com
# Log in with Monzo, approve on your phone, copy the access_token
# Tokens expire after a few hours; refresh as needed
MONZO_ACCESS_TOKEN=
MONZO_USER_ID=

# Trading 212 — generate API key in the app: Settings > API
T212_API_KEY=
T212_ENVIRONMENT=live

# Optional: override T212 export poll timeout (seconds, default 300)
# T212_POLL_TIMEOUT=300
